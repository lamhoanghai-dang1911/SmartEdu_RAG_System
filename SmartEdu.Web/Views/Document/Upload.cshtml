@{
    ViewData["Title"] = "Upload tài liệu";
}

<div class="container mt-4" style="max-width:600px">
    <h2>⬆️ Upload tài liệu</h2>
    <hr />

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            @foreach (var error in ViewData.ModelState.Values
                .SelectMany(v => v.Errors))
            {
                <div>@error.ErrorMessage</div>
            }
        </div>
    }

    <form asp-action="Upload" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label class="form-label">Tiêu đề tài liệu</label>
            <input name="title" class="form-control"
                   placeholder="VD: Bài giảng Chương 1" required />
        </div>

        <div class="mb-3">
            <label class="form-label">Môn học</label>
            <select name="subjectId" asp-items="ViewBag.Subjects"
                    class="form-select" required>
                <option value="">-- Chọn môn học --</option>
            </select>
        </div>

    <div id="uploadPermissionAlert" class="alert alert-danger" style="display:none;"></div>

        <div class="mb-3">
            <label class="form-label">File (PDF hoặc DOCX)</label>
            <input name="file" type="file" class="form-control"
                   accept=".pdf,.docx" required />
            <div class="form-text">Chỉ hỗ trợ .pdf và .docx</div>
        </div>

        <button type="submit" id="uploadBtn" class="btn btn-primary" disabled>
            💾 Upload
        </button>
        <a asp-action="Index" class="btn btn-secondary">← Quay lại</a>
    </form>
</div>

@section Scripts {
    <script>
        (function(){
            const select = document.querySelector('select[name="subjectId"]');
            const uploadBtn = document.getElementById('uploadBtn');
            const alertEl = document.getElementById('uploadPermissionAlert');

            async function check(subjectId) {
                if (!subjectId) {
                    uploadBtn.setAttribute('disabled','disabled');
                    alertEl.style.display = 'none';
                    return;
                }
                try {
                    const resp = await fetch(`/Document/CanUpload?subjectId=${subjectId}`, { credentials: 'same-origin', cache: 'no-store', headers: { 'Accept': 'application/json' } });
                    if (!resp.ok) {
                        uploadBtn.setAttribute('disabled','disabled');
                        alertEl.style.display = 'none';
                        return;
                    }
                    const j = await resp.json();
                    if (j.canUpload) {
                        uploadBtn.removeAttribute('disabled');
                        alertEl.style.display = 'none';
                    } else {
                        uploadBtn.setAttribute('disabled','disabled');
                        alertEl.textContent = j.message || 'Bạn không có quyền upload tài liệu cho môn này. Chỉ trưởng môn được phép.';
                        alertEl.style.display = 'block';
                    }
                } catch (e) {
                    console.error(e);
                }
            }

            select.addEventListener('change', function(){ check(this.value); });
            // initial check if a subject preselected (small delay to ensure items bound)
            if (select.value) setTimeout(()=>check(select.value), 150);
        })();
    </script>
}
