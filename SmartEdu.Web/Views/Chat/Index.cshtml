@{
    ViewData["Title"] = "Chat RAG";
    var currentSessionId = ViewBag.CurrentSessionId as string;
    var history = ViewBag.History as IEnumerable<SmartEdu.Shared.DTOs.ChatMessageDto>
                  ?? Enumerable.Empty<SmartEdu.Shared.DTOs.ChatMessageDto>();
    var sessions = ViewBag.Sessions as IEnumerable<SmartEdu.Shared.DTOs.ChatSessionDto>
                   ?? Enumerable.Empty<SmartEdu.Shared.DTOs.ChatSessionDto>();
}

<style>
    .chat-panel {
        height: calc(100vh - 120px);
        display: flex;
        flex-direction: column;
    }

    .chat-messages {
        flex: 1 1 auto;
        overflow-y: auto;
        -webkit-overflow-scrolling: touch;
    }

    .chat-input-area {
        flex: 0 0 auto;
    }

    .sidebar-panel {
        height: calc(100vh - 120px);
        display: flex;
        flex-direction: column;
    }

    .sidebar-header {
        flex: 0 0 auto;
        background: #fff;
        z-index: 2;
    }

    .sidebar-list {
        flex: 1 1 auto;
        overflow-y: auto;
        -webkit-overflow-scrolling: touch;
        background: transparent;
    }
</style>

<div class="container-fluid mt-3">
    <div class="row" style="height: calc(100vh - 120px)">
        <div class="col-md-3">
            <div class="sidebar-panel border-end d-flex flex-column">

                <div class="sidebar-header p-2 d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">💬 Phiên chat</h6>
                    <a href="@Url.Action("Index", "Chat")" class="btn btn-sm btn-primary">+ Mới</a>
                </div>

                <div class="sidebar-list p-2">
                    @foreach (var s in sessions)
                    {
                        <div class="card mb-2 shadow-sm @(s.SessionId == currentSessionId ? "border-primary" : "")">
                            <div class="card-body p-2">
                                <div class="d-flex justify-content-between">
                                    <a href="@Url.Action("Index", "Chat", new { sessionId = s.SessionId })"
                                       class="text-decoration-none text-dark fw-bold small text-truncate"
                                       style="max-width:150px">
                                        @(s.Title ?? "Phiên mới")
                                    </a>
                                    <form asp-action="DeleteSession" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="sessionId" value="@s.SessionId" />
                                        <button type="submit" class="btn btn-sm btn-link text-danger p-0" onclick="return confirm('Xóa phiên này?')">🗑️</button>
                                    </form>
                                </div>
                                <small class="text-muted">📚 @s.SubjectName | 💬 @s.MessageCount tin</small>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-9">
            <div class="chat-panel border d-flex flex-column">

                <div class="d-flex align-items-center gap-2 mb-2 p-2">
                    <h5 id="chatTitle" class="mb-0">🤖 @ViewBag.CurrentSessionTitle</h5>
    
                    <select id="subjectSelect" asp-items="ViewBag.Subjects"
                            class="form-select form-select-sm w-auto">
                        <option value="">-- Tất cả môn học --</option>
                    </select>
                </div>

                @* Messages area: grows and scrolls *@
                <div id="chatBox" class="chat-messages p-3 bg-light mb-2">

                    @if (!history.Any())
                    {
                        <div id="emptyMsg" class="text-center text-muted mt-5">
                            <h4>👋 Xin chào!</h4>
                            <p>Hãy đặt câu hỏi về tài liệu học tập của bạn.</p>
                        </div>
                    }

                    @foreach (var msg in history)
                    {
                        if (msg.Role == "user")
                        {
                            <div class="d-flex justify-content-end mb-2">
                                <div class="bg-primary text-white rounded p-2 px-3 chat-message-content" style="max-width:75%">
                                    @msg.Content
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="d-flex justify-content-start mb-2">
                                <div class="bg-white border rounded p-2 px-3 chat-message-content" style="max-width:75%">
                                    <small class="text-muted d-block mb-1">🤖 SmartEdu AI</small>
                                    @* Dùng thẻ div để render markdown cũ *@
                                    <div class="markdown-body">@Html.Raw(msg.Content.Replace("\n", "<br/>"))</div>
                                </div>
                            </div>
                        }
                    }
                </div>

                @* Input area fixed at bottom of panel *@
                <div class="chat-input-area p-2 bg-white border-top">
                    <div id="typingIndicator" class="text-muted small mb-1 d-none">
                        🤖 Đang trả lời...
                    </div>

                    <div class="input-group">
                        <textarea id="questionInput" class="form-control" rows="1"
                                  placeholder="Enter để gửi, Shift+Enter xuống dòng..." autocomplete="off"></textarea>
                        <button id="sendBtn" class="btn btn-primary" type="button">➤ Gửi</button>
                    </div>

                    <small class="text-muted mt-1 d-block d-none">
                        Enter để gửi • Shift+Enter xuống dòng • Session: <code>@currentSessionId</code>
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const sessionId   = "@currentSessionId";
        const chatBox     = document.getElementById("chatBox");
        const input       = document.getElementById("questionInput");
        const sendBtn     = document.getElementById("sendBtn");
        const typing      = document.getElementById("typingIndicator");
        const emptyMsg    = document.getElementById("emptyMsg");

        // Scroll xuống cuối
        function scrollBottom() {
            chatBox.scrollTop = chatBox.scrollHeight;
        }
        scrollBottom();

        // Autosize textarea to content
        function autosizeTextarea(el, maxHeight = 400) {
            if (!el) return;
            el.style.height = 'auto';
            const newH = Math.min(el.scrollHeight, maxHeight);
            el.style.height = newH + 'px';
        }

        // Render markdown safely into element by id
        function renderChatMarkdown(containerId, markdownText) {
            const container = document.getElementById(containerId);
            if (!container) return;
            if (typeof marked !== 'undefined' && typeof DOMPurify !== 'undefined') {
                marked.setOptions({ gfm: true, breaks: true, smartLists: true, smartypants: false });
                const raw = marked.parse(markdownText ?? '');
                const safe = DOMPurify.sanitize(raw);
                container.classList.add('chat-message-content');
                container.innerHTML = safe;
            } else {
                container.classList.add('chat-message-content');
                container.textContent = (markdownText ?? '').replace(/\\n/g, '\n');
            }
        }

        // Thêm bubble tin nhắn
        function appendMessage(role, content) {
            if (emptyMsg) emptyMsg.remove();

            const wrapper = document.createElement("div");
            wrapper.className = `d-flex mb-2 ${role === "user"
                ? "justify-content-end"
                : "justify-content-start"}`;

            const bubble = document.createElement("div");
            bubble.style.maxWidth = "75%";

            if (role === "user") {
                bubble.className = "bg-primary text-white rounded p-2 px-3";
                // Use textContent but preserve newlines visually via CSS pre-wrap
                bubble.classList.add('chat-message-content');
                bubble.textContent = content.replace(/\\n/g, '\n');
            } else {
                bubble.className = "bg-white border rounded p-2 px-3";
                // Create a temporary container to render markdown safely
                const tmpId = 'tmp_' + Date.now() + '_' + Math.random().toString(36).slice(2,6);
                const header = `<small class="text-muted d-block mb-1">🤖 SmartEdu AI</small>`;
                bubble.innerHTML = header + `<div id="${tmpId}"></div>`;
                // Render markdown into that inner div
                // Use setTimeout to ensure element is in DOM
                setTimeout(() => renderChatMarkdown(tmpId, content), 0);
            }

            wrapper.appendChild(bubble);
            chatBox.appendChild(wrapper);
            scrollBottom();
        }

        // Gửi câu hỏi
        async function sendMessage() {
            const questionRaw = input.value;
            const question = questionRaw.trim();
            if (!question) return;

            const subjectId = document.getElementById("subjectSelect").value;

            input.value = "";
            autosizeTextarea(input);
            sendBtn.disabled = true;
            appendMessage("user", questionRaw);
            typing.classList.remove("d-none");

            try {
                const res = await fetch("/Chat/Ask", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        sessionId,
                        question,
                        subjectId: subjectId ? parseInt(subjectId) : null
                    })
                });

                const data = await res.json();

                typing.classList.add("d-none");

                if (res.ok) {
                    appendMessage("assistant", data.answer);

                    // Hiển thị sources nếu có
                    if (data.sources && data.sources.length > 0) {
                        const srcDiv = document.createElement("div");
                        srcDiv.className = "text-muted small ms-2 mb-2";
                        srcDiv.innerHTML = "📎 Nguồn: " +
                            data.sources.map(s => `<em>${s}</em>`).join(", ");
                        chatBox.appendChild(srcDiv);
                        scrollBottom();
                    }
                } else {
                    appendMessage("assistant", "❌ Lỗi: " + data.error);
                }
            } catch (err) {
                typing.classList.add("d-none");
                appendMessage("assistant", "❌ Không thể kết nối server.");
            } finally {
                sendBtn.disabled = false;
                input.focus();
            }
        }

        // Event listeners
        sendBtn.addEventListener("click", sendMessage);
        // Initialize autosize
        autosizeTextarea(input);
        input.addEventListener('input', () => autosizeTextarea(input));
        input.addEventListener("keydown", e => {
            if (e.key === "Enter" && !e.shiftKey) {
                e.preventDefault();
                sendMessage();
            }
            // Shift+Enter => allow newline
        });
            document.addEventListener("DOMContentLoaded", function() {
            const selectEl = document.getElementById("subjectSelect");
            const selectedValue = "@(ViewBag.Subjects?.SelectedValue ?? "")";
            if (selectedValue) {
                selectEl.value = selectedValue;
            }
        });
    </script>
}