@{
    ViewData["Title"] = "Quản lý giảng viên - phân công môn học";
}

<h2>@ViewData["Title"]</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="row">
    <div class="col-md-6">
        <form asp-action="Assign" method="post">
            <div class="form-group mb-2">
                <label>Giảng viên</label>
                <select class="form-control" name="LecturerId">
                    <option value="">-- Chọn giảng viên --</option>
                    @foreach (var l in (Microsoft.AspNetCore.Mvc.Rendering.SelectList)ViewBag.Lecturers)
                    {
                        <option value="@l.Value">@l.Text</option>
                    }
                </select>
            </div>
            <div class="form-group mb-2">
                <label>Môn học</label>
                <select class="form-control" name="SubjectId">
                    <option value="">-- Chọn môn học --</option>
                    @foreach (var s in (Microsoft.AspNetCore.Mvc.Rendering.SelectList)ViewBag.Subjects)
                    {
                        <option value="@s.Value">@s.Text</option>
                    }
                </select>
            </div>
            <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" value="true" id="IsLeader" name="IsLeader" />
                <label class="form-check-label" for="IsLeader">Đặt làm trưởng môn</label>
            </div>
            <button type="submit" class="btn btn-primary">Gán</button>
        </form>
    </div>

    <div class="col-md-6">
        <h4>Danh sách phân công</h4>
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Giảng viên</th>
                    <th>Môn học</th>
                    <th>Trưởng môn</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in (IEnumerable<SmartEdu.Shared.Entities.LecturerSubject>)ViewBag.Assignments)
                {
                    <tr>
                        <td>@a.Lecturer?.FullName</td>
                        <td>@a.Subject?.Name</td>
                        <td>@(a.IsLeader ? "Có" : "—")</td>
                        <td>
                            <div class="btn-group" role="group">
                                <form asp-action="Unassign" method="post" style="display:inline">
                                    <input type="hidden" name="lecturerId" value="@a.LecturerId" />
                                    <input type="hidden" name="subjectId" value="@a.SubjectId" />
                                    <button class="btn btn-sm btn-danger" type="submit">Hủy</button>
                                </form>
                                @if (!a.IsLeader)
                                {
                                    <form asp-action="SetLeader" method="post" style="display:inline; margin-left:6px;">
                                        <input type="hidden" name="lecturerId" value="@a.LecturerId" />
                                        <input type="hidden" name="subjectId" value="@a.SubjectId" />
                                        <button class="btn btn-sm btn-success" type="submit">Đặt trưởng</button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
